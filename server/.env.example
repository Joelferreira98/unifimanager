DATABASE_URL=postgresql://user:password@localhost:5432/unifi_hotspot

UNIFI_HOST=https://192.168.1.1
UNIFI_API_KEY=sua_api_key_gerada_em_settings_integrations
UNIFI_SITE_ID=uuid-do-site-padrao

JWT_SECRET=troque_por_uma_string_aleatoria_longa
JWT_EXPIRES_IN=8h

# Intervalo em minutos para sincronizar vouchers com o UniFi
VOUCHER_SYNC_INTERVAL_MINUTES=2

# Insights de IA nos relatórios (OpenAI). Opcional: sem a chave, a página de
# Relatórios funciona, apenas o botão "Gerar insights" fica indisponível.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Seed
MASTER_EMAIL=master@admin.com
MASTER_PASSWORD=changeme
