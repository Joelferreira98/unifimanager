generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER
  MANAGER
  SELLER
}

enum VoucherStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  role        Role
  active      Boolean  @default(true)

  // Permite ao usuário (concedido pelo MASTER) ver o relatório geral de todas as embarcações.
  canViewGlobalReports Boolean @default(false)

  createdById String?
  createdBy   User?    @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]  @relation("UserCreatedBy")

  // MANAGER
  managedCompanies ManagerCompany[]

  // SELLER
  companyId   String?
  company     Company? @relation("SellerCompany", fields: [companyId], references: [id])
  vouchers    Voucher[]
  sales       Sale[]   @relation("SellerSales")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Company {
  id          String   @id @default(uuid())
  name        String
  unifiSiteId String
  active      Boolean  @default(true)

  managers    ManagerCompany[]
  sellers     User[]   @relation("SellerCompany")
  plans       Plan[]
  trips       Trip[]
  voucherTemplate VoucherTemplate?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ManagerCompany {
  managerId   String
  companyId   String
  manager     User    @relation(fields: [managerId], references: [id])
  company     Company @relation(fields: [companyId], references: [id])

  @@id([managerId, companyId])
}

model Plan {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id])
  name                 String
  price                Decimal  @db.Decimal(10, 2)
  timeLimitMinutes     Int
  dataUsageLimitMBytes Int?
  rxRateLimitKbps      Int?
  txRateLimitKbps      Int?
  active               Boolean  @default(true)

  vouchers             Voucher[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Trip {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  active      Boolean   @default(true)
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  vouchers    Voucher[]
  sales       Sale[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId, active])
}

model Voucher {
  id             String        @id @default(uuid())
  unifiVoucherId String?       @unique
  code           String        @unique
  status         VoucherStatus @default(PENDING)

  planId         String
  plan           Plan          @relation(fields: [planId], references: [id])

  companyId      String

  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])

  tripId         String
  trip           Trip          @relation(fields: [tripId], references: [id])

  generatedAt    DateTime      @default(now())
  activatedAt    DateTime?
  expiresAt      DateTime?

  sale           Sale?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([tripId, status])
}

model Sale {
  id           String   @id @default(uuid())
  voucherId    String   @unique
  voucher      Voucher  @relation(fields: [voucherId], references: [id])

  tripId       String
  trip         Trip     @relation(fields: [tripId], references: [id])

  sellerId     String
  seller       User     @relation("SellerSales", fields: [sellerId], references: [id])
  amount       Decimal  @db.Decimal(10, 2)

  registeredAt DateTime

  createdAt    DateTime @default(now())
}

// Personalização do voucher impresso, por empresa (1:1 com Company).
// logo é guardado como data URL (base64).
model VoucherTemplate {
  id           String   @id @default(uuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id])

  // Logo
  logoUrl      String?

  // Cores
  bgColor      String   @default("#ffffff")
  textColor    String   @default("#111111")
  accentColor  String   @default("#0075ff")
  borderColor  String   @default("#999999")

  // Textos (null = usa o padrão)
  headerText   String?  // título do card (padrão: nome da empresa)
  subtitle     String?  // rótulo acima do código (padrão: "Código de acesso")
  wifiName     String?  // nome da rede WiFi (SSID)
  instructions String?  // instruções de conexão
  footerText   String?  // rodapé

  // Layout
  cardsPerRow  Int      @default(3)
  showLogo     Boolean  @default(true)
  showPrice    Boolean  @default(true)
  showPlan     Boolean  @default(true)
  showDuration Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Configurações de marca/aparência da aplicação (linha única — singleton).
// logo/favicon são guardados como data URL (base64).
model AppSettings {
  id           String   @id @default("singleton")
  appName      String   @default("UniFi Hotspot")
  logoUrl      String?
  faviconUrl   String?
  primaryColor String   @default("#0075ff")
  gradientFrom String   @default("#0075ff")
  gradientTo   String   @default("#21d4fd")
  updatedAt    DateTime @updatedAt
}
